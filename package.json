{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/windyroad/agent-plugins.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "bats": "^1.13.0",
    "bats-assert": "^2.2.4",
    "bats-support": "^0.3.0"
  },
  "scripts": {
    "test": "bats --recursive packages/*/hooks/test/ packages/*/skills/*/test/ packages/*/agents/test/ packages/*/scripts/test/ packages/shared/test/ .claude/skills/*/test/",
    "sync:install-utils": "bash scripts/sync-install-utils.sh",
    "check:install-utils": "bash scripts/sync-install-utils.sh --check",
    "sync:session-marker": "bash scripts/sync-session-marker.sh",
    "check:session-marker": "bash scripts/sync-session-marker.sh --check",
    "sync:external-comms-gate": "bash scripts/sync-external-comms-gate.sh",
    "check:external-comms-gate": "bash scripts/sync-external-comms-gate.sh --check",
    "sync:derive-first-dispatch": "bash scripts/sync-derive-first-dispatch.sh",
    "check:derive-first-dispatch": "bash scripts/sync-derive-first-dispatch.sh --check",
    "sync:migrate-problems-layout": "bash scripts/sync-migrate-problems-layout.sh",
    "check:migrate-problems-layout": "bash scripts/sync-migrate-problems-layout.sh --check",
    "sync:plugin-manifests": "node scripts/sync-plugin-manifests.mjs",
    "check:plugin-manifests": "node scripts/sync-plugin-manifests.mjs --check",
    "version": "changeset version && node scripts/sync-plugin-manifests.mjs",
    "release": "changeset publish",
    "release:watch": "bash scripts/release-watch.sh",
    "push:watch": "bash scripts/push-watch.sh"
  }
}
