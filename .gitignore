.DS_Store
*.tmp
node_modules/
*.tgz

# Runtime artifacts (created by risk-scorer hooks)
.risk-reports/
.env

# Skill eval workspaces (test-infrastructure scratch output per skill-creator)
*-workspace/

# Per-project consent caches — per-machine, never committed (P120 / ADR-034)
.claude/.install-updates-consent
.claude/.auto-install-consent

# AFK runtime state — per-session, never committed (ADR-032 subprocess-boundary)
.afk-run-state/
.claude/scheduled_tasks.lock

# RFC capture deny log — measurement surface per ADR-060 § Reassessment
# (trace-violation-rate criterion). Per-session telemetry; CI runs and
# local development should not commit deny entries.
logs/
